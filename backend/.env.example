DJANGO_DEBUG=1
DJANGO_SECRET_KEY=django-insecure-ledgerlift-mvp-dev
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8088,http://127.0.0.1:8088
LEDGERLIFT_ALLOWED_ORIGINS=http://localhost:8088,http://127.0.0.1:8088,http://localhost:8000,http://127.0.0.1:8000
LEDGERLIFT_API_BASE_URL=http://localhost:8001/api

# Render can provide a single DATABASE_URL. Leave it empty for local SQLite.
DATABASE_URL=

# Or set these individually when you want to point local development at PostgreSQL.
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Keep these empty until the URA integration is available.
URA_TIN_LOOKUP_BASE_URL=
URA_TIN_LOOKUP_API_KEY=